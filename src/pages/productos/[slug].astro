---
import Layout from '../../layouts/Layout.astro';
import { getProductBySlug, products } from '../../data/products';
import { withBase } from '../../utils/site';

export function getStaticPaths() {
	return products.map((product) => ({
		params: { slug: product.slug },
		props: { product },
	}));
}

const { product } = Astro.props;
const relatedProducts = products
	.filter((item) => item.category === product.category && item.slug !== product.slug)
	.slice(0, 3);
const whatsappText = encodeURIComponent(
	`Hola, quiero pedir ${product.name} de Chocolates Artesanales. ¿Me puedes compartir opciones de compra y entrega?`,
);
---

<Layout title={`${product.name} | Chocolates Artesanales`} description={product.description}>
	<main class="pb-20">
		<section class="section-shell pt-8">
			<a
				href={withBase('/')}
				class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-[var(--color-rose)] transition hover:border-[var(--color-gold)]/40 hover:text-white"
			>
				← Volver al catálogo
			</a>
		</section>

		<section class="section-shell grid gap-8 pt-6 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
			<div class="glass-panel shine-card fade-up relative overflow-hidden rounded-[2.25rem] border border-white/10 p-3">
				<img
					src={withBase(product.image)}
					alt={product.alt}
					class="h-[420px] w-full rounded-[1.75rem] object-cover md:h-[560px]"
				/>
			</div>

			<div class="fade-up space-y-6" style="animation-delay:140ms;">
				<div class="space-y-4">
					<span class="inline-flex rounded-full border border-[var(--color-gold)]/30 bg-[var(--color-gold)]/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-gold)]">
						{product.line}
					</span>
					<h1 class="text-5xl leading-tight text-[var(--color-cream)] md:text-6xl">{product.name}</h1>
					<p class="max-w-2xl text-lg leading-8 text-[var(--color-rose)]/90">{product.description}</p>
				</div>

				<div class="grid gap-4 sm:grid-cols-2">
					<div class="glass-panel rounded-[1.6rem] border border-white/10 p-5">
						<p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-gold)]">Presentación ideal</p>
						<p class="mt-3 text-sm leading-6 text-[var(--color-cream)]/85">{product.presentation}</p>
					</div>
					<div class="glass-panel rounded-[1.6rem] border border-white/10 p-5">
						<p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-gold)]">Ideal para</p>
						<p class="mt-3 text-sm leading-6 text-[var(--color-cream)]/85">{product.idealFor}</p>
					</div>
				</div>

				<div class="glass-panel rounded-[1.8rem] border border-white/10 p-5">
					<p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-gold)]">Notas clave</p>
					<div class="mt-4 flex flex-wrap gap-3">
						{product.notes.map((note) => (
							<span class="rounded-full border border-white/10 bg-black/15 px-4 py-2 text-sm text-[var(--color-cream)]/85">
								{note}
							</span>
						))}
					</div>
				</div>

				<div class="flex flex-wrap gap-3">
					<a
						href={`https://api.whatsapp.com/send?text=${whatsappText}`}
						target="_blank"
						rel="noreferrer"
						class="inline-flex items-center justify-center rounded-full bg-[var(--color-gold)] px-6 py-3 text-sm font-extrabold text-[var(--color-ink)] transition hover:bg-[#f2d7a5]"
					>
						Pedir por WhatsApp
					</a>
					<a
						href={withBase('/#catalogo')}
						class="inline-flex items-center justify-center rounded-full border border-white/10 px-6 py-3 text-sm font-bold text-[var(--color-cream)] transition hover:border-[var(--color-gold)]/40 hover:bg-white/5"
					>
						Ver más productos
					</a>
				</div>
			</div>
		</section>

		{relatedProducts.length > 0 && (
			<section class="section-shell pt-16">
				<div class="mb-6 flex items-end justify-between gap-4">
					<div>
						<p class="text-sm uppercase tracking-[0.28em] text-[var(--color-gold)]">Sigue explorando</p>
						<h2 class="mt-2 text-3xl text-[var(--color-cream)]">Más opciones de esta línea</h2>
					</div>
				</div>
				<div class="grid gap-5 md:grid-cols-3">
					{relatedProducts.map((item) => (
						<a
							href={`/productos/${item.slug}`}
							class="glass-panel group overflow-hidden rounded-[1.75rem] border border-white/10 p-3 transition hover:-translate-y-1 hover:border-[var(--color-gold)]/50"
						>
							<img
								src={withBase(item.image)}
								alt={item.alt}
								class="h-56 w-full rounded-[1.2rem] object-cover transition duration-500 group-hover:scale-[1.03]"
							/>
							<div class="p-3">
								<h3 class="text-xl text-[var(--color-cream)]">{item.name}</h3>
								<p class="mt-2 text-sm leading-6 text-[var(--color-rose)]/85">{item.shortDescription}</p>
							</div>
						</a>
					))}
				</div>
			</section>
		)}
	</main>
</Layout>
