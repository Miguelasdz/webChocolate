---
import '../styles/global.css';
import { withBase } from '../utils/site';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Chocolates Artesanales',
	description = 'Tienda artesanal de chocolates finos con líneas semiamargas, de leche y especialidades para regalo o antojo.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
		<link rel="icon" href={withBase('/favicon.ico')} />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body class="bg-[var(--color-ink)] text-[var(--color-cream)] antialiased">
		<slot />
	</body>
</html>
